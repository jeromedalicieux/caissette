---
import Base from '../../layouts/Base.astro'

const articles = [
  {
    slug: 'ouvrir-depot-vente-guide-complet',
    title: 'Comment ouvrir un depot-vente : guide complet',
    description: 'Tout ce qu\'il faut savoir pour ouvrir un commerce de depot-vente en France : statut juridique, obligations, logiciel de caisse, rentabilite.',
    date: '2026-04-21',
  },
  {
    slug: 'certification-nf525-guide',
    title: 'Certification NF525 : tout comprendre en 5 minutes',
    description: 'La certification NF525 est obligatoire pour tout logiciel de caisse en France. Voici ce qu\'elle exige et comment s\'y conformer.',
    date: '2026-04-21',
  },
  {
    slug: 'logiciel-caisse-petit-commerce',
    title: 'Quel logiciel de caisse pour un petit commerce ?',
    description: 'Comparatif des solutions de caisse pour les petits commerces : criteres de choix, prix, conformite, et pourquoi l\'open source change la donne.',
    date: '2026-04-21',
  },
]
---

<Base
  title="Blog — Caissette, logiciel de caisse open source"
  description="Articles et guides sur la gestion de caisse, la conformite fiscale, le depot-vente et le commerce en France."
>
  <section class="mx-auto max-w-3xl px-6 py-20">
    <h1 class="text-4xl font-bold text-gray-900">Blog</h1>
    <p class="mt-4 text-gray-600">Guides pratiques, conformite fiscale, et conseils pour les commercants.</p>

    <div class="mt-12 space-y-10">
      {articles.map((article) => (
        <article class="group">
          <a href={`/blog/${article.slug}`} class="block">
            <p class="text-sm text-gray-400">{new Date(article.date).toLocaleDateString('fr-FR', { dateStyle: 'long' })}</p>
            <h2 class="mt-1 text-xl font-semibold text-gray-900 group-hover:text-blue-600 transition-colors">{article.title}</h2>
            <p class="mt-2 text-gray-600">{article.description}</p>
          </a>
        </article>
      ))}
    </div>
  </section>
</Base>
