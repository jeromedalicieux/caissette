---
import Base from '../layouts/Base.astro'
---

<Base title="Mentions legales — Caissette" description="Mentions legales du site caissette.fr">
  <section class="mx-auto max-w-3xl px-6 py-20">
    <h1 class="text-3xl font-bold text-gray-900">Mentions legales</h1>
    <div class="mt-8 space-y-6 text-sm text-gray-600 leading-relaxed">
      <div>
        <h2 class="font-semibold text-gray-900 text-base">Editeur</h2>
        <p class="mt-2">Caissette — Logiciel de caisse open source<br />Contact : contact@caissette.fr</p>
      </div>
      <div>
        <h2 class="font-semibold text-gray-900 text-base">Hebergement</h2>
        <p class="mt-2">Cloudflare, Inc.<br />101 Townsend St, San Francisco, CA 94107, USA</p>
      </div>
      <div>
        <h2 class="font-semibold text-gray-900 text-base">Propriete intellectuelle</h2>
        <p class="mt-2">Le logiciel Caissette est distribue sous licence AGPL-3.0. Le code source est disponible sur <a href="https://github.com/caissette/caissette" class="text-blue-600 hover:underline" target="_blank" rel="noopener">GitHub</a>.</p>
      </div>
    </div>
  </section>
</Base>
